def check_token_format(closure_file, workspace, plan_id):
    """praxis.closure.token-format"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    _token, fields = _parse_closure_token(content)
    if not fields:
        return ("FAIL", f"no closure token found in {os.path.basename(closure_file)}")
    missing = [
        f for f in ("plan", "evidence", "last-line", "at")
        if not fields.get(f)
    ]
    if missing:
        return ("FAIL", f"token missing non-empty fields: {missing}")
    if "sha256" in fields and not re.fullmatch(r"[0-9a-fA-F]{64}", fields["sha256"]):
        return ("FAIL", "sha256 field must be 64 hexadecimal characters")
    return ("PASS", f"token found: plan={fields['plan']} at={fields['at']}")


def check_evidence_exists(closure_file, workspace, plan_id):
    """praxis.closure.evidence-exists"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    _token, fields = _parse_closure_token(content)
    if not fields:
        return ("FAIL", "no closure token found; cannot check evidence")
    evidence_path = fields.get("evidence")
    if not evidence_path:
        return ("FAIL", "closure token missing evidence field")
    resolved = _resolve_evidence_path(workspace, evidence_path)
    if os.path.isfile(resolved):
        return ("PASS", f"evidence exists: {evidence_path}")
    return ("FAIL", f"evidence file not found: {evidence_path} (resolved: {resolved})")


def check_last_line_matches(closure_file, workspace, plan_id):
    """praxis.closure.last-line-matches"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    _token, fields = _parse_closure_token(content)
    if not fields:
        return ("FAIL", "no closure token found; cannot check last-line")
    tok_last = fields.get("last-line")
    evidence_path = fields.get("evidence")
    if tok_last is None or not evidence_path:
        return ("FAIL", "closure token missing last-line or evidence field")
    resolved = _resolve_evidence_path(workspace, evidence_path)
    if not os.path.isfile(resolved):
        return ("FAIL", f"evidence file not found: {resolved}")
    try:
        lines = Path(resolved).read_text(encoding="utf-8").splitlines()
    except OSError as e:
        return ("FAIL", f"cannot read evidence file: {e}")
    non_empty = [l.rstrip() for l in lines if l.strip()]
    if not non_empty:
        return ("FAIL", "evidence file has no non-empty lines")
    actual_last = non_empty[-1]
    if actual_last == tok_last:
        return ("PASS", f"last-line matches: \"{tok_last}\"")
    return (
        "FAIL",
        f"last-line mismatch\n       expected: \"{tok_last}\"\n       actual:   \"{actual_last}\"",
    )


def check_timestamp_parseable(closure_file, workspace, plan_id):
    """praxis.closure.timestamp-parseable"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    _token, fields = _parse_closure_token(content)
    if not fields:
        return ("FAIL", "no closure token found; cannot check timestamp")
    ts = fields.get("at", "").rstrip("]").rstrip()
    ts_normalized = ts.replace("Z", "+00:00")
    try:
        datetime.datetime.fromisoformat(ts_normalized)
        return ("PASS", f"timestamp parses: {ts}")
    except ValueError as e:
        return ("FAIL", f"timestamp not ISO-8601: \"{ts}\" ({e})")


def check_evidence_sha256_matches(closure_file, workspace, plan_id):
    """praxis.closure.evidence-sha256-matches"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    _token, fields = _parse_closure_token(content)
    if not fields:
        return ("FAIL", "no closure token found; cannot check sha256")
    expected = fields.get("sha256")
    if not expected:
        return ("WARN", "closure token has no sha256 field; legacy last-line-only binding")
    evidence_path = fields.get("evidence")
    if not evidence_path:
        return ("FAIL", "closure token missing evidence field")
    resolved = _resolve_evidence_path(workspace, evidence_path)
    if not os.path.isfile(resolved):
        return ("FAIL", f"evidence file not found: {resolved}")
    try:
        actual = _sha256_file(resolved)
    except OSError as e:
        return ("FAIL", f"cannot hash evidence file: {e}")
    if actual.lower() == expected.lower():
        return ("PASS", f"sha256 matches: {actual}")
    return ("FAIL", f"sha256 mismatch\n       expected: {expected}\n       actual:   {actual}")


def _read_plan_id(path):
    try:
        content = Path(path).read_text(encoding="utf-8")
    except OSError:
        return None
    m = re.search(r"^##\s+Plan ID\s*\n+([^\n]+)", content, re.MULTILINE)
    if m:
        return m.group(1).strip().strip("`")
    return None


def _find_plan_files(workspace):
    patterns = [
        os.path.join(workspace, "plans", "active", "*.md"),
        os.path.join(workspace, "_meta", "plan-v*.md"),
        os.path.join(workspace, "plan-v*.md"),
    ]
    found = []
    for pat in patterns:
        found.extend(glob.glob(pat))
    return sorted(set(found))


def _find_plan_ids(workspace):
    ids = []
    for path in _find_plan_files(workspace):
        pid = _read_plan_id(path)
        if pid:
            ids.append(pid)
    return sorted(set(ids))


def _execution_log_candidates(workspace):
    return [
        os.path.join(workspace, "logs", "execution-log.md"),
        os.path.join(workspace, "_meta", "execution-log.md"),
        os.path.join(workspace, "execution-log.md"),
    ]


def _self_eval_candidates(workspace):
    return [
        os.path.join(workspace, "validation", "self-evaluation.md"),
        os.path.join(workspace, "_meta", "validation", "self-evaluation.md"),
        os.path.join(workspace, "self-evaluation.md"),
    ]


def _handoff_outbox_dirs(workspace):
    return [
        os.path.join(workspace, "handoffs", "outbox"),
        os.path.join(workspace, "_meta", "handoffs", "outbox"),
    ]


def check_mode_rubric_exists(closure_file, workspace, plan_id):
    """praxis.mode.rubric-exists"""
    plan_ids = [plan_id] if plan_id else _find_plan_ids(workspace)
    if not plan_ids:
        return ("INFO", "no active plan IDs found; mode rubric check not applicable")

    missing = []
    for pid in plan_ids:
        rubric_path = os.path.join(workspace, "_meta", "mode-decisions", f"{pid}.md")
        if not os.path.isfile(rubric_path):
            missing.append(pid)
    if not missing:
        return ("PASS", f"mode rubric exists for {len(plan_ids)} plan(s)")
    return ("FAIL", f"mode rubric missing for: {', '.join(missing)}")


def check_plan_exists(closure_file, workspace, plan_id):
    """praxis.plan.exists"""
    found = _find_plan_files(workspace)
    if found:
        names = [os.path.basename(f) for f in found]
        return ("PASS", f"plan file(s) found: {', '.join(names)}")
    return ("FAIL", "no plan-v*.md found in plans/active/ or _meta/")


def check_eval_skipped(closure_file, workspace, plan_id):
    """praxis.eval.skipped-non-empty"""
    for path in _self_eval_candidates(workspace):
        if os.path.isfile(path):
            try:
                content = Path(path).read_text(encoding="utf-8")
            except OSError:
                continue
            # Look for Skipped Rules section
            m = re.search(r"##\s+Skipped Rules(.+?)(?=\n##|\Z)", content, re.DOTALL)
            if m:
                section = m.group(1).strip()
                lines = [l for l in section.splitlines() if l.strip()]
                if len(lines) >= 1:
                    return ("PASS", "Skipped Rules section has entries")
                return ("WARN", "Skipped Rules section appears empty (false purity suspect)")
            return ("WARN", "no Skipped Rules section found in self-evaluation.md")
    return ("INFO", "no self-evaluation.md found; skipping check")


def check_log_article_tagged(closure_file, workspace, plan_id):
    """praxis.log.article-tagged"""
    tag_re = re.compile(r"\[§\d+")
    for path in _execution_log_candidates(workspace):
        if os.path.isfile(path):
            try:
                lines = Path(path).read_text(encoding="utf-8").splitlines()
            except OSError:
                continue
            # Look for decision-class action lines without tags
            decision_lines = [l for l in lines if re.search(r"\b(decide|classify|skip-rule|claim-closure)\b", l, re.IGNORECASE)]
            untagged = [l for l in decision_lines if not tag_re.search(l)]
            if untagged:
                return ("WARN", f"{len(untagged)} untagged decision-class action(s) in execution-log.md")
            return ("PASS", "all decision-class actions tagged (or no decision lines found)")
    return ("INFO", "no execution-log.md found; skipping check")


def check_handoff_packet_exists(closure_file, workspace, plan_id):
    """praxis.handoff.packet-exists"""
    dispatches = _find_dispatches(workspace)
    if dispatches is None:
        return ("INFO", "no execution-log.md found; skipping check")
    if not dispatches:
        return ("PASS", "no subagent dispatches found in execution-log.md")

    missing = []
    deep_missing = []
    for dispatch in dispatches:
        packet = _find_packet_file(workspace, dispatch["task_id"])
        if not packet:
            missing.append(dispatch["task_id"])
            if dispatch.get("mode") in ("agentic", "deep", "recovery"):
                deep_missing.append(dispatch["task_id"])
    if missing:
        msg = f"no packet found for: {', '.join(missing)}"
        if deep_missing:
            return ("FAIL", msg + " (mode-aware escalation for agentic/deep/recovery dispatch)")
        return ("WARN", msg)
    return ("PASS", f"all {len(dispatches)} dispatch(es) have packet files")


def _find_dispatches(workspace):
    dispatches = []
    saw_log = False
    for path in _execution_log_candidates(workspace):
        if os.path.isfile(path):
            saw_log = True
            try:
                lines = Path(path).read_text(encoding="utf-8").splitlines()
            except OSError:
                continue
            for line in lines:
                if "dispatch-subagent" not in line:
                    continue
                fields = line.split("\t")
                mode = fields[1].strip() if len(fields) > 1 else "unknown"
                target = fields[4].strip() if len(fields) > 4 else line
                task_id = _extract_dispatch_task_id(target)
                dispatches.append({
                    "task_id": task_id,
                    "mode": mode,
                    "target": target,
                    "line": line,
                })
    if not saw_log:
        return None
    return dispatches


def _extract_dispatch_task_id(target):
    for pattern in (
        r"\btask-id=([A-Za-z0-9_.-]+)",
        r"\btask=([A-Za-z0-9_.-]+)",
        r"\bid=([A-Za-z0-9_.-]+)",
        r"\bpacket=([A-Za-z0-9_.-]+)",
        r"Task packet:\s*([A-Za-z0-9_.-]+)",
    ):
        m = re.search(pattern, target)
        if m:
            return m.group(1).removesuffix(".md")

    cleaned = re.sub(r"\[[^\]]+\]", " ", target)
    tokens = [t for t in cleaned.split() if "=" not in t and not t.startswith("[")]
    return tokens[0].removesuffix(".md") if tokens else "unknown-dispatch"


def _find_packet_file(workspace, task_id):
    if not task_id:
        return None
    names = [task_id, f"{task_id}.md"]
    for outbox in _handoff_outbox_dirs(workspace):
        for name in names:
            path = os.path.join(outbox, name)
            if os.path.isfile(path):
                return path
    return None


def check_thin_dispatch(closure_file, workspace, plan_id):
    """praxis.handoff.thin-dispatch"""
    dispatches = _find_dispatches(workspace)
    if dispatches is None:
        return ("INFO", "no execution-log.md found; skipping check")
    if not dispatches:
        return ("PASS", "no subagent dispatches found in execution-log.md")

    warnings = []
    checked = 0
    for dispatch in dispatches:
        packet = _find_packet_file(workspace, dispatch["task_id"])
        if not packet:
            continue
        try:
            text = Path(packet).read_text(encoding="utf-8")
        except OSError:
            continue
        checked += 1
        line_tokens = len(dispatch["target"].split())
        has_packet_marker = "Task packet:" in dispatch["target"] or "task-packet" in dispatch["target"].lower()
        if len(text) > 1000 and not has_packet_marker:
            warnings.append(f"{dispatch['task_id']} long packet lacks Task packet: dispatch marker")
        if line_tokens > 300:
            warnings.append(f"{dispatch['task_id']} dispatch target is ~{line_tokens} tokens (>300)")

    if warnings:
        return ("WARN", "; ".join(warnings))
    if checked:
        return ("PASS", f"thin-dispatch approximation passed for {checked} packet-backed dispatch(es)")
    return ("INFO", "dispatches found but no packet files available; packet-exists rule covers this")


