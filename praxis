# ---------------------------------------------------------------------------
# ANSI helpers
# ---------------------------------------------------------------------------

def _is_tty():
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()

_COLORS = {
    "PASS": "\033[32m",
    "FAIL": "\033[31m",
    "WARN": "\033[33m",
    "INFO": "\033[36m",
    "RESET": "\033[0m",
}

def _color(status, text):
    if _is_tty():
        return _COLORS.get(status, "") + text + _COLORS["RESET"]
    return text

# ---------------------------------------------------------------------------
# Workspace detection
# ---------------------------------------------------------------------------

def detect_workspace(cwd, override=None):
    """Return (workspace_path_str, runtime) or exit(2)."""
    home = str(Path.home())

    def _has_meta(p):
        return (
            os.path.isdir(os.path.join(p, ".claude"))
            or os.path.isdir(os.path.join(p, ".codex"))
            or os.path.isdir(os.path.join(p, "_meta", "mode-decisions"))
        )

    if override is not None:
        op = os.path.abspath(override)
        if not _has_meta(op) and not os.path.isdir(os.path.join(op, "validation")):
            # Also accept if the path itself looks like a harness root
            if not (
                os.path.isdir(os.path.join(op, "_meta"))
                or os.path.basename(op) in (".claude", ".codex")
            ):
                sys.exit(
                    2,
                )
        # Decide runtime
        if os.path.basename(op) in (".claude", ".codex") or os.path.isdir(
            os.path.join(op, "_meta")
        ):
            runtime = "harness-meta"
        elif os.path.isdir(os.path.join(op, ".claude")):
            return os.path.join(op, ".claude"), "claude"
        elif os.path.isdir(os.path.join(op, ".codex")):
            return os.path.join(op, ".codex"), "codex"
        else:
            runtime = "harness-meta"
        return op, runtime

    # Walk from cwd upward
    candidate = os.path.abspath(cwd)
    while True:
        if os.path.isdir(os.path.join(candidate, ".claude")):
            return os.path.join(candidate, ".claude"), "claude"
        if os.path.isdir(os.path.join(candidate, ".codex")):
            return os.path.join(candidate, ".codex"), "codex"
        parent = os.path.dirname(candidate)
        if parent == candidate:
            break
        candidate = parent

    # Check if cwd itself is a harness root
    cwd_abs = os.path.abspath(cwd)
    if os.path.basename(cwd_abs) in (".claude", ".codex"):
        return cwd_abs, "harness-meta"
    if os.path.isdir(os.path.join(cwd_abs, "_meta", "mode-decisions")):
        return cwd_abs, "harness-meta"
    # Also handle if cwd IS ~/.claude or similar
    if os.path.isdir(os.path.join(cwd_abs, "_meta")):
        return cwd_abs, "harness-meta"

    print(
        "error: not a Praxis workspace; cd into a project with .claude/ or .codex/, "
        "or pass --workspace",
        file=sys.stderr,
    )
    sys.exit(2)

# ---------------------------------------------------------------------------
# Closure token regex
# ---------------------------------------------------------------------------

CLOSURE_TOKEN_RE = re.compile(r"\[CLOSURE:\s+(?P<body>[^\]]+)\]")
TOKEN_FIELD_RE = re.compile(r"([A-Za-z][A-Za-z0-9-]*)=(\"[^\"]*\"|\S+)")


def _parse_closure_token(content):
    """Return (token_text, fields) for the first closure token in content."""
    m = CLOSURE_TOKEN_RE.search(content)
    if not m:
        return (None, None)
    fields = {}
    for key, raw in TOKEN_FIELD_RE.findall(m.group("body")):
        if raw.startswith('"') and raw.endswith('"'):
            fields[key] = raw[1:-1]
        else:
            fields[key] = raw
    return (m.group(0), fields)


def _resolve_evidence_path(workspace, evidence_path):
    if not evidence_path:
        return None
    if os.path.isfile(evidence_path):
        return evidence_path
    resolved = os.path.join(workspace, evidence_path)
    if os.path.isfile(resolved):
        return resolved
    return resolved


def _sha256_file(path):
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

