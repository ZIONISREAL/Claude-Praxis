def cmd_list_rules(args):
    if getattr(args, "json", False):
        payload = {
            "version": __version__,
            "rules": [
                {k: v for k, v in rule.items() if k != "check"}
                for rule in RULES
            ],
        }
        print(_json_payload(payload, brief=getattr(args, "brief", False)))
        return 0
    header = f"{'ID':<45} {'SEVERITY':<10} {'IMPLEMENTED'}"
    print(header)
    print("-" * len(header))
    for rule in RULES:
        impl = "yes" if rule["implemented"] else "no (manual)"
        print(f"{rule['id']:<45} {rule['severity']:<10} {impl}")
    return 0


def cmd_explain(args):
    rule_id = args.rule_id
    for rule in RULES:
        if rule["id"] == rule_id:
            print(f"{rule['id']} (severity={rule['severity']}, tier={rule['tier']})")
            print()
            print(rule["description"])
            if rule.get("constitutional_reference"):
                print()
                print(f"Reference: {rule['constitutional_reference']}")
            return 0
    print(f"error: unknown rule id: {rule_id}", file=sys.stderr)
    return 1


def cmd_check(args, workspace, runtime, lint_mode=False):
    human = not getattr(args, "json", False)
    brief = getattr(args, "brief", False)
    if human:
        print(f"Praxis Doctor v{__version__} — workspace: {workspace} (runtime: {runtime})")
    closure_files = _find_closure_files(workspace)
    all_results = []

    if closure_files:
        for cf in closure_files:
            pid = _plan_id_from_filename(cf)
            if human and not brief:
                print(f"\n--- closure: {pid} ---")
            closure_rules = [r for r in RULES if r["id"] in CLOSURE_RULE_IDS]
            results = _run_rules(closure_rules, cf, workspace, pid)
            if human:
                _print_result_set(results, brief=brief)
            all_results.extend([dict(r, subject=pid) for r in results])
    else:
        if human and not brief:
            print("\n(no closure files found)")

    # Workspace-level rules (non-closure)
    if human and not brief:
        print("\n--- workspace ---")
    ws_rules = [r for r in RULES if r["id"] not in CLOSURE_RULE_IDS]
    ws_results = _run_rules(ws_rules, None, workspace, None)
    if human:
        _print_result_set(ws_results, brief=brief)
    all_results.extend([dict(r, subject="workspace") for r in ws_results])

    counts = _count(all_results)
    exit_code = 0 if (counts.get("fail", 0) == 0 or lint_mode) else 1

    if human:
        _print_summary(counts)
        if brief:
            print(f"Exit code: {exit_code}")
    else:
        out = {
            "version": __version__,
            "workspace": workspace,
            "runtime": runtime,
            "results": all_results,
            "summary": counts,
            "exit_code": exit_code,
        }
        print(_json_payload(out, brief=brief))

    if lint_mode:
        return 0
    return 1 if counts.get("fail", 0) > 0 else 0


def _find_token_in_self_eval(workspace, plan_id):
    """Search self-evaluation.md files for a CLOSURE token matching plan_id.

    Returns (token_text, source_path) or (None, None).
    """
    candidates = [
        os.path.join(workspace, "validation", "self-evaluation.md"),
        os.path.join(workspace, "_meta", "validation", "self-evaluation.md"),
    ]
    pattern = re.compile(
        r"\[CLOSURE:\s+plan=" + re.escape(plan_id) + r"\b[^\]]*\]"
    )
    for p in candidates:
        if not os.path.isfile(p):
            continue
        try:
            content = Path(p).read_text(encoding="utf-8")
        except OSError:
            continue
        m = pattern.search(content)
        if m:
            return (m.group(0), p)
    return (None, None)


def cmd_verify_closure(args, workspace, runtime):
    plan_id = args.plan_id
    token_text = None
    source_label = None

    # Source 1: --token explicit
    if getattr(args, "token", None):
        token_text = args.token
        source_label = "--token flag (explicit)"

    # Source 2/3: self-evaluation.md
    if token_text is None:
        tok, src = _find_token_in_self_eval(workspace, plan_id)
        if tok:
            token_text = tok
            source_label = f"self-evaluation.md ({src})"

    # Source 4: legacy — closure file embedded
    if token_text is None:
        cf = _locate_closure_file(workspace, plan_id)
        if cf:
            try:
                content = Path(cf).read_text(encoding="utf-8")
            except OSError:
                content = ""
            if CLOSURE_TOKEN_RE.search(content):
                token_text = content
                source_label = f"closure file (legacy): {cf}"

    if token_text is None:
        print(
            f"error: no closure token found for plan '{plan_id}'\n"
            f"  searched (in order):\n"
            f"    1. --token flag (not provided)\n"
            f"    2. {workspace}/validation/self-evaluation.md\n"
            f"    3. {workspace}/_meta/validation/self-evaluation.md\n"
            f"    4. closure file (legacy embed)",
            file=sys.stderr,
        )
        return 2

    # Write resolved token text to a temp file so rule functions can read it
    import tempfile
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".md", delete=False, encoding="utf-8"
    ) as tf:
        tf.write(token_text)
        temp_path = tf.name

    try:
        human = not getattr(args, "json", False)
        brief = getattr(args, "brief", False)
        if human:
            print(f"Praxis Doctor v{__version__} — verify-closure: {plan_id}")
            print(f"workspace: {workspace} (runtime: {runtime})")
            print(f"token source: {source_label}\n")

        closure_rules = [r for r in RULES if r["id"] in CLOSURE_RULE_IDS]
        results = _run_rules(closure_rules, temp_path, workspace, plan_id)
        if human:
            _print_result_set(results, brief=brief)

        counts = _count(results)
        exit_code = 0 if counts.get("fail", 0) == 0 else 1

        if human:
            _print_summary(counts)
            if brief:
                print(f"Exit code: {exit_code}")
        else:
            out = {
                "version": __version__,
                "workspace": workspace,
                "runtime": runtime,
                "plan_id": plan_id,
                "token_source": source_label,
                "results": [dict(r, subject=plan_id) for r in results],
                "summary": counts,
                "exit_code": exit_code,
            }
            print(_json_payload(out, brief=brief))
    finally:
        try:
            os.unlink(temp_path)
        except OSError:
            pass

    return 1 if counts.get("fail", 0) > 0 else 0


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="praxis",
        description="Praxis Doctor — verification layer for Claude-Praxis harness.",
    )
    parser.add_argument("--version", action="version", version=f"Praxis v{__version__}")
    parser.add_argument(
        "--workspace",
        metavar="PATH",
        default=None,
        help="override workspace auto-detection",
    )

    subparsers = parser.add_subparsers(dest="command", metavar="<subcommand>")

    # version subcommand
    ver_parser = subparsers.add_parser("version", help="print version")

    # doctor subcommand
    doctor_parser = subparsers.add_parser("doctor", help="doctor subcommands")
    doctor_sub = doctor_parser.add_subparsers(dest="doctor_cmd", metavar="<cmd>")

    # doctor check
    check_parser = doctor_sub.add_parser("check", help="run all checks; exit 1 on any FAIL")
    check_parser.add_argument("--json", action="store_true", help="machine-readable JSON output")
    check_parser.add_argument("--brief", action="store_true", help="compact output for agent control flow")
    check_parser.add_argument("--workspace", metavar="PATH", default=None, help="override workspace auto-detection")

    # doctor verify-closure
    vc_parser = doctor_sub.add_parser("verify-closure", help="strict verification of one closure token")
    vc_parser.add_argument("plan_id", metavar="<plan-id>")
    vc_parser.add_argument("--token", metavar="STR", default=None,
                           help="explicit closure token text (overrides self-eval / file search)")
    vc_parser.add_argument("--json", action="store_true", help="machine-readable JSON output")
    vc_parser.add_argument("--brief", action="store_true", help="compact output for agent control flow")
    vc_parser.add_argument("--workspace", metavar="PATH", default=None, help="override workspace auto-detection")

    # doctor lint
    lint_parser = doctor_sub.add_parser("lint", help="non-blocking warnings only; always exit 0")
    lint_parser.add_argument("--json", action="store_true", help="machine-readable JSON output")
    lint_parser.add_argument("--brief", action="store_true", help="compact output for agent control flow")
    lint_parser.add_argument("--workspace", metavar="PATH", default=None, help="override workspace auto-detection")

    # doctor list-rules
    lr_parser = doctor_sub.add_parser("list-rules", help="print rule IDs with severity")
    lr_parser.add_argument("--json", action="store_true", help="machine-readable JSON output")
    lr_parser.add_argument("--brief", action="store_true", help="compact JSON output")

    # doctor explain
    exp_parser = doctor_sub.add_parser("explain", help="print description of one rule")
    exp_parser.add_argument("rule_id", metavar="<rule-id>")

    args = parser.parse_args()

    # version subcommand
    if args.command == "version":
        print(f"Praxis v{__version__}")
        return 0

    # list-rules / explain don't need workspace
    if args.command == "doctor":
        if args.doctor_cmd == "list-rules":
            return cmd_list_rules(args)
        if args.doctor_cmd == "explain":
            return cmd_explain(args)

        # For check/verify-closure/lint we need workspace
        workspace, runtime = detect_workspace(os.getcwd(), override=getattr(args, "workspace", None))

        if args.doctor_cmd == "check":
            return cmd_check(args, workspace, runtime, lint_mode=False)
        elif args.doctor_cmd == "lint":
            args.json = getattr(args, "json", False)
            return cmd_check(args, workspace, runtime, lint_mode=True)
        elif args.doctor_cmd == "verify-closure":
            return cmd_verify_closure(args, workspace, runtime)
        else:
            doctor_parser.print_help()
            return 1
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    sys.exit(main())
