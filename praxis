def _fmt_result(rule_id, status, message):
    tag = f"[{status}]"
    colored_tag = _color(status, tag)
    lines = message.splitlines()
    first = lines[0] if lines else ""
    rest = "\n".join("       " + l for l in lines[1:])
    out = f"{colored_tag} {rule_id}: {first}"
    if rest:
        out += "\n" + rest
    return out


def _print_summary(counts):
    parts = []
    for status in ("pass", "fail", "warn", "info"):
        n = counts.get(status, 0)
        label = f"{n} {status}"
        if status == "fail" and n:
            label = _color("FAIL", label)
        elif status == "warn" and n:
            label = _color("WARN", label)
        parts.append(label)
    print("\nSummary: " + " · ".join(parts))


def _run_rules(rules, closure_file, workspace, plan_id):
    results = []
    for rule in rules:
        status, message = rule["check"](closure_file, workspace, plan_id)
        results.append({
            "rule": rule["id"],
            "status": status,
            "severity": rule.get("severity", "info"),
            "tier": rule.get("tier"),
            "message": message,
        })
    return results


def _count(results):
    counts = {"pass": 0, "fail": 0, "warn": 0, "info": 0}
    for r in results:
        counts[r["status"].lower()] = counts.get(r["status"].lower(), 0) + 1
    return counts


def _json_payload(payload, brief=False):
    if brief:
        payload = dict(payload)
        if "results" in payload:
            payload["results"] = [
                r for r in payload.get("results", [])
                if r.get("status") != "PASS"
            ]
        return json.dumps(payload, separators=(",", ":"))
    return json.dumps(payload, indent=2)


def _print_result_set(results, brief=False):
    visible = [r for r in results if not brief or r["status"] != "PASS"]
    for res in visible:
        print(_fmt_result(res["rule"], res["status"], res["message"]))


def _find_closure_files(workspace):
    """Find all closure-*.md files in validation dirs."""
    patterns = [
        os.path.join(workspace, "validation", "closure-*.md"),
        os.path.join(workspace, "_meta", "validation", "closure-*.md"),
    ]
    found = []
    for pat in patterns:
        found.extend(glob.glob(pat))
    return sorted(set(found))


def _plan_id_from_file(path):
    """closure-plan-praxis-v12-v001.md → plan-praxis-v12-v001"""
    base = os.path.basename(path)
    if base.startswith("closure-"):
        return base[len("closure-"):].rstrip(".md")[:-3] if base.endswith(".md") else base[len("closure-"):]
    return base


def _plan_id_from_filename(path):
    """closure-plan-praxis-v12-v001.md → plan-praxis-v12-v001"""
    base = os.path.basename(path)
    # strip .md
    if base.endswith(".md"):
        base = base[:-3]
    # strip leading closure-
    if base.startswith("closure-"):
        base = base[len("closure-"):]
    return base


def _locate_closure_file(workspace, plan_id):
    # Build slug variants: some closure files omit the "plan-" prefix in their filename
    slugs = [plan_id]
    if plan_id.startswith("plan-"):
        slugs.append(plan_id[len("plan-"):])

    dirs = [
        os.path.join(workspace, "validation"),
        os.path.join(workspace, "_meta", "validation"),
    ]
    for d in dirs:
        for slug in slugs:
            c = os.path.join(d, f"closure-{slug}.md")
            if os.path.isfile(c):
                return c
    return None


