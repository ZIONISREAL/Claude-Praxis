def _manual_check(closure_file, workspace, plan_id):
    return ("INFO", "manual review only")


def _load_rules():
    rules_path = Path(__file__).with_name("rules.json")
    try:
        payload = json.loads(rules_path.read_text(encoding="utf-8"))
    except OSError as e:
        print(f"error: cannot read rules source {rules_path}: {e}", file=sys.stderr)
        sys.exit(2)
    except json.JSONDecodeError as e:
        print(f"error: invalid rules source {rules_path}: {e}", file=sys.stderr)
        sys.exit(2)

    rules = []
    for meta in payload.get("rules", []):
        rule = dict(meta)
        check = CHECK_FUNCTIONS.get(rule["id"], _manual_check)
        rule["check"] = check
        rule["implemented"] = check is not _manual_check and rule.get("check_status") != "manual"
        rules.append(rule)
    return rules


RULES = _load_rules()
CLOSURE_RULE_IDS = {r["id"] for r in RULES if r["id"].startswith("praxis.closure.")}


