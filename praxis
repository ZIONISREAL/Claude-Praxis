# ---------------------------------------------------------------------------
# ANSI helpers
# ---------------------------------------------------------------------------

def _is_tty():
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()

_COLORS = {
    "PASS": "\033[32m",
    "FAIL": "\033[31m",
    "WARN": "\033[33m",
    "INFO": "\033[36m",
    "RESET": "\033[0m",
}

def _color(status, text):
    if _is_tty():
        return _COLORS.get(status, "") + text + _COLORS["RESET"]
    return text

# ---------------------------------------------------------------------------
# Workspace detection
# ---------------------------------------------------------------------------

def detect_workspace(cwd, override=None):
    """Return (workspace_path_str, runtime) or exit(2)."""
    home = str(Path.home())

    def _has_meta(p):
        return (
            os.path.isdir(os.path.join(p, ".claude"))
            or os.path.isdir(os.path.join(p, ".codex"))
            or os.path.isdir(os.path.join(p, "_meta", "mode-decisions"))
        )

    if override is not None:
        op = os.path.abspath(override)
        if not _has_meta(op) and not os.path.isdir(os.path.join(op, "validation")):
            # Also accept if the path itself looks like a harness root
            if not (
                os.path.isdir(os.path.join(op, "_meta"))
                or os.path.basename(op) in (".claude", ".codex")
            ):
                sys.exit(
                    2,
                )
        # Decide runtime
        if os.path.basename(op) in (".claude", ".codex") or os.path.isdir(
            os.path.join(op, "_meta")
        ):
            runtime = "harness-meta"
        elif os.path.isdir(os.path.join(op, ".claude")):
            return os.path.join(op, ".claude"), "claude"
        elif os.path.isdir(os.path.join(op, ".codex")):
            return os.path.join(op, ".codex"), "codex"
        else:
            runtime = "harness-meta"
        return op, runtime

    # Walk from cwd upward
    candidate = os.path.abspath(cwd)
    while True:
        if os.path.isdir(os.path.join(candidate, ".claude")):
            return os.path.join(candidate, ".claude"), "claude"
        if os.path.isdir(os.path.join(candidate, ".codex")):
            return os.path.join(candidate, ".codex"), "codex"
        parent = os.path.dirname(candidate)
        if parent == candidate:
            break
        candidate = parent

    # Check if cwd itself is a harness root
    cwd_abs = os.path.abspath(cwd)
    if os.path.basename(cwd_abs) in (".claude", ".codex"):
        return cwd_abs, "harness-meta"
    if os.path.isdir(os.path.join(cwd_abs, "_meta", "mode-decisions")):
        return cwd_abs, "harness-meta"
    # Also handle if cwd IS ~/.claude or similar
    if os.path.isdir(os.path.join(cwd_abs, "_meta")):
        return cwd_abs, "harness-meta"

    print(
        "error: not a Praxis workspace; cd into a project with .claude/ or .codex/, "
        "or pass --workspace",
        file=sys.stderr,
    )
    sys.exit(2)

# ---------------------------------------------------------------------------
# Closure token regex
# ---------------------------------------------------------------------------

CLOSURE_TOKEN_RE = re.compile(
    r"\[CLOSURE:\s+plan=(\S+)\s+evidence=(\S+)\s+last-line=\"([^\"]*)\"\s+at=(\S+?)(?:\s+verifier=\S+)?\]"
)

# ---------------------------------------------------------------------------
# Rule implementations
# ---------------------------------------------------------------------------

def check_token_format(closure_file, workspace, plan_id):
    """praxis.closure.token-format"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    m = CLOSURE_TOKEN_RE.search(content)
    if not m:
        return ("FAIL", f"no closure token found in {os.path.basename(closure_file)}")
    tok_plan = m.group(1)
    tok_evidence = m.group(2)
    tok_last = m.group(3)
    tok_at = m.group(4)
    missing = [f for f, v in [("plan", tok_plan), ("evidence", tok_evidence), ("last-line", tok_last), ("at", tok_at)] if not v]
    if missing:
        return ("FAIL", f"token missing non-empty fields: {missing}")
    return ("PASS", f"token found: plan={tok_plan} at={tok_at}")


def check_evidence_exists(closure_file, workspace, plan_id):
    """praxis.closure.evidence-exists"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    m = CLOSURE_TOKEN_RE.search(content)
    if not m:
        return ("FAIL", "no closure token found; cannot check evidence")
    evidence_path = m.group(2)
    resolved = os.path.join(workspace, evidence_path)
    if os.path.isfile(resolved):
        return ("PASS", f"evidence exists: {evidence_path}")
    # Try absolute path too
    if os.path.isfile(evidence_path):
        return ("PASS", f"evidence exists (absolute): {evidence_path}")
    return ("FAIL", f"evidence file not found: {evidence_path} (resolved: {resolved})")


def check_last_line_matches(closure_file, workspace, plan_id):
    """praxis.closure.last-line-matches"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    m = CLOSURE_TOKEN_RE.search(content)
    if not m:
        return ("FAIL", "no closure token found; cannot check last-line")
    tok_last = m.group(3)
    evidence_path = m.group(2)
    resolved = os.path.join(workspace, evidence_path)
    if not os.path.isfile(resolved):
        if os.path.isfile(evidence_path):
            resolved = evidence_path
        else:
            return ("FAIL", f"evidence file not found: {resolved}")
    try:
        lines = Path(resolved).read_text(encoding="utf-8").splitlines()
    except OSError as e:
        return ("FAIL", f"cannot read evidence file: {e}")
    non_empty = [l.rstrip() for l in lines if l.strip()]
    if not non_empty:
        return ("FAIL", "evidence file has no non-empty lines")
    actual_last = non_empty[-1]
    if actual_last == tok_last:
        return ("PASS", f"last-line matches: \"{tok_last}\"")
    return (
        "FAIL",
        f"last-line mismatch\n       expected: \"{tok_last}\"\n       actual:   \"{actual_last}\"",
    )


def check_timestamp_parseable(closure_file, workspace, plan_id):
    """praxis.closure.timestamp-parseable"""
    try:
        content = Path(closure_file).read_text(encoding="utf-8")
    except OSError as e:
        return ("FAIL", f"cannot read {closure_file}: {e}")
    m = CLOSURE_TOKEN_RE.search(content)
    if not m:
        return ("FAIL", "no closure token found; cannot check timestamp")
    ts = m.group(4).rstrip("]").rstrip()
    ts_normalized = ts.replace("Z", "+00:00")
    try:
        datetime.datetime.fromisoformat(ts_normalized)
        return ("PASS", f"timestamp parses: {ts}")
    except ValueError as e:
        return ("FAIL", f"timestamp not ISO-8601: \"{ts}\" ({e})")


def check_mode_rubric_exists(closure_file, workspace, plan_id):
    """praxis.mode.rubric-exists"""
    rubric_path = os.path.join(workspace, "_meta", "mode-decisions", f"{plan_id}.md")
    if os.path.isfile(rubric_path):
        return ("PASS", f"mode rubric exists: _meta/mode-decisions/{plan_id}.md")
    return ("FAIL", f"mode rubric not found: {rubric_path}")


def check_plan_exists(closure_file, workspace, plan_id):
    """praxis.plan.exists"""
    # For harness-meta, look in _meta/; otherwise plans/active/
    patterns = [
        os.path.join(workspace, "plans", "active", "plan-v*.md"),
        os.path.join(workspace, "_meta", "plan-v*.md"),
        os.path.join(workspace, "plan-v*.md"),
    ]
    for pat in patterns:
        found = glob.glob(pat)
        if found:
            names = [os.path.basename(f) for f in found]
            return ("PASS", f"plan file(s) found: {', '.join(names)}")
    return ("FAIL", "no plan-v*.md found in plans/active/ or _meta/")


def check_eval_skipped(closure_file, workspace, plan_id):
    """praxis.eval.skipped-non-empty"""
    candidates = [
        os.path.join(workspace, "self-evaluation.md"),
        os.path.join(workspace, "_meta", "self-evaluation.md"),
        os.path.join(workspace, "validation", "self-evaluation.md"),
    ]
    for path in candidates:
        if os.path.isfile(path):
            try:
                content = Path(path).read_text(encoding="utf-8")
            except OSError:
                continue
            # Look for Skipped Rules section
            m = re.search(r"##\s+Skipped Rules(.+?)(?=\n##|\Z)", content, re.DOTALL)
            if m:
                section = m.group(1).strip()
                lines = [l for l in section.splitlines() if l.strip()]
                if len(lines) >= 1:
                    return ("PASS", "Skipped Rules section has entries")
                return ("WARN", "Skipped Rules section appears empty (false purity suspect)")
            return ("WARN", "no Skipped Rules section found in self-evaluation.md")
    return ("INFO", "no self-evaluation.md found; skipping check")


def check_log_article_tagged(closure_file, workspace, plan_id):
    """praxis.log.article-tagged"""
    candidates = [
        os.path.join(workspace, "execution-log.md"),
        os.path.join(workspace, "_meta", "execution-log.md"),
    ]
    tag_re = re.compile(r"\[§\d+")
    for path in candidates:
        if os.path.isfile(path):
            try:
                lines = Path(path).read_text(encoding="utf-8").splitlines()
            except OSError:
                continue
            # Look for decision-class action lines without tags
            decision_lines = [l for l in lines if re.search(r"\b(decide|classify|skip-rule|claim-closure)\b", l, re.IGNORECASE)]
            untagged = [l for l in decision_lines if not tag_re.search(l)]
            if untagged:
                return ("WARN", f"{len(untagged)} untagged decision-class action(s) in execution-log.md")
            return ("PASS", "all decision-class actions tagged (or no decision lines found)")
    return ("INFO", "no execution-log.md found; skipping check")


def check_handoff_packet_exists(closure_file, workspace, plan_id):
    """praxis.handoff.packet-exists"""
    candidates = [
        os.path.join(workspace, "execution-log.md"),
        os.path.join(workspace, "_meta", "execution-log.md"),
    ]
    dispatch_re = re.compile(r"dispatch-subagent\s+(\S+)", re.IGNORECASE)
    for path in candidates:
        if os.path.isfile(path):
            try:
                content = Path(path).read_text(encoding="utf-8")
            except OSError:
                continue
            dispatches = dispatch_re.findall(content)
            if not dispatches:
                return ("PASS", "no subagent dispatches found in execution-log.md")
            missing = []
            outbox = os.path.join(workspace, "_meta", "handoffs", "outbox")
            for sa_id in dispatches:
                packet = os.path.join(outbox, f"{sa_id}.md")
                if not os.path.isfile(packet):
                    missing.append(sa_id)
            if missing:
                return ("WARN", f"no packet found for: {', '.join(missing)}")
            return ("PASS", f"all {len(dispatches)} dispatch(es) have packet files")
    return ("INFO", "no execution-log.md found; skipping check")


